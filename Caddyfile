{$DOMAIN} {
  encode zstd gzip

  @uploads path /uploads* /api/uploads*
  handle @uploads {
    reverse_proxy backend:5000
  }

  @api_proxy path /api/proxy* /api/proxy/*
  handle @api_proxy {
    reverse_proxy frontend:3000
  }

  handle {
    reverse_proxy frontend:3000
  }
}
